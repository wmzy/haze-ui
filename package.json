{
  "name": "haze-ui",
  "version": "0.0.0",
  "type": "module",
  "description": "A React UI component library powered by react-use-control and Linaria",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/haze-ui.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "start": "vite",
    "build": "BUILD_LIB=true vite build && tsc -p tsconfig.lib.json && tsc-alias -p tsconfig.lib.json",
    "build:demo": "BABEL_ENV=development BUILD_DEMO=true vite build && cp dist/index.html dist/404.html",
    "commit": "lint-staged && git-cz -n",
    "coverage": "vitest run --coverage",
    "lint": "eslint --fix src *.mjs",
    "deploy": "npm run build:demo && gh-pages -d dist",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "serve": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wmzy/haze-ui.git"
  },
  "keywords": [
    "react",
    "ui",
    "component",
    "library",
    "haze-ui"
  ],
  "author": "wmzy",
  "license": "MIT",
  "peerDependencies": {
    "@linaria/core": "^7.0.0",
    "react": "^19.0.0"
  },
  "dependencies": {
    "babel-runtime-jsx-plus": "^0.1.5",
    "react-toolroom": "^0.5.2",
    "react-use-control": "^1.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@faker-js/faker": "^10.3.0",
    "@for-fun/event-emitter": "^1.0.0",
    "@linaria/core": "^7.0.0",
    "@native-router/core": "^1.1.0",
    "@native-router/react": "^1.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/ramda": "^0.31.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "@wyw-in-js/babel-preset": "^1.0.6",
    "@wyw-in-js/vite": "^1.0.6",
    "babel-plugin-transform-jsx-class": "^0.1.3",
    "babel-plugin-transform-jsx-condition": "^0.1.3",
    "babel-runtime-jsx-plus": "^0.1.5",
    "commitizen": "^4.3.1",
    "core-js": "^3.49.0",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-compat": "^7.0.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "json-schema-faker": "^0.6.0",
    "lint-staged": "^16.4.0",
    "lucide-react": "^0.577.0",
    "prettier": "^3.8.1",
    "qss": "^3.0.0",
    "ramda": "^0.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "rollup-plugin-type-as-json-schema": "^0.2.6",
    "semantic-release": "^25.0.3",
    "terser": "^5.46.1",
    "tools-config": "^0.2.5",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
