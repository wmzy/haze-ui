{
  "extends": "tools-config/typescript",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"]
    },
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/types",
    "rootDir": "src/lib"
  },
  "include": ["src/lib"],
  "exclude": ["src/lib/**/*.test.*", "src/lib/**/*.spec.*"]
}
